# PostgreSQL (Neon) connection
DATABASE_URL=postgresql://localhost:5432/hypaper

# Redis connection — supports redis:// and rediss:// (TLS)
REDIS_URL=redis://localhost:6379

# HyperLiquid endpoints
HL_WS_URL=wss://api.hyperliquid.xyz/ws
HL_API_URL=https://api.hyperliquid.xyz

# Server
PORT=3000

# Paper trading
DEFAULT_BALANCE=100000

# Logging: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# WebSocket reconnect tuning (ms)
WS_RECONNECT_MIN_MS=1000
WS_RECONNECT_MAX_MS=30000

# L2 order book transport. true (default): subscribe to HL's l2Book over
# WebSocket and read the book Redis-first in the matcher. false: skip the
# subscription and fall back to HTTP /info l2Book polling (original behavior).
# Kill-switch to roll the WS path back without a redeploy.
L2_WS_ENABLED=true

# Rate limiting (per IP, per window) — matches HL prod's 1200 req/min
# IP limit. /info, /exchange, and /hypaper share one bucket per IP, so
# the cap has to cover both polling traffic AND user actions. 120 is
# too tight: a typical SPA client polling /info 4× every 2 s burns
# 120/min on its own, leaving zero headroom for /exchange actions.
RATE_LIMIT_MAX=1200
RATE_LIMIT_WINDOW_MS=60000

# Chart-drawing snapshot NFT indexer (HyperEVM ERC-721).
# Set CHART_DRAWINGS_INDEXER_ENABLED=true to start the indexer worker
# on boot. Requires CHART_NFT_CONTRACT (deployed address) and
# CHART_NFT_DEPLOY_BLOCK (block at which the contract was deployed,
# used as the backfill starting point on first run).
CHART_DRAWINGS_INDEXER_ENABLED=false
HYPEREVM_RPC=https://rpc.hyperliquid.xyz/evm
# CHART_NFT_CONTRACT=0x...
# CHART_NFT_DEPLOY_BLOCK=...
CHART_INDEXER_POLL_MS=5000
# HyperEVM RPC caps eth_getLogs at 1000 blocks per query. Keep this at
# 999 (one under the cap) unless you're using an alternative RPC with
# a higher limit.
CHART_INDEXER_MAX_BLOCK_RANGE=999
